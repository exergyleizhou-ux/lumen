{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lumen Science",
  "version": "1.2.0-science-beta.2",
  "identifier": "com.lumen.science.acceptance",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Lumen Science",
        "width": 420,
        "height": 720,
        "minWidth": 360,
        "minHeight": 560,
        "resizable": true,
        "center": true,
        "url": "http://127.0.0.1:18990/"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    }
  }
}