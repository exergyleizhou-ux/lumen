# API keys per provider. NOTE: the base URL is NOT read from the environment —
# set base_url in lumen.toml's [[providers]] block instead.

# DeepSeek
DEEPSEEK_API_KEY=sk-...

# OpenAI (optional)
OPENAI_API_KEY=sk-...

# Grok (optional)
GROK_API_KEY=xai-...

# Hosted Workbench only. The control-plane URL must be the Oasis backend base
# URL. Use a distinct random runtime credential of at least 32 bytes; it is
# machine-to-machine and must not be exposed to browsers.
WORKBENCH_CONTROL_PLANE_URL=http://oasis-backend:8080
WORKBENCH_RUNTIME_INGEST_SECRET=

# Hosted production profile. Copy only variable names into your secret manager;
# never commit populated values. Pin immutable image digests in production.
LUMEN_IMAGE=ghcr.io/example/lumen@sha256:replace-with-release-digest
LUMEN_PREVIOUS_IMAGE=ghcr.io/example/lumen@sha256:replace-with-previous-digest
LUMEN_HOSTED=true
WORKBENCH_JWT_SECRET=
WORKBENCH_DATABASE_URL=postgres://lumen:replace@postgres:5432/oasis?sslmode=require
WORKBENCH_OBJECT_DIR=/var/lib/lumen/objects
HOSTED_WORKSPACE_ROOT=/var/lib/lumen/workspaces
WORKBENCH_PARENT_ORIGIN=https://workbench.example.com
LUMEN_CODE_HOST=code.internal.example.com
LUMEN_LAB_HOST=lab.internal.example.com
LUMEN_PROVIDER_API_KEY=
