    {
      "id": "deepseek-chat",
      "model": "deepseek-chat",
      "name": "DeepSeek V4 Flash",
      "description": "DeepSeek V4 Flash — fast, via deepseek-chat alias, 99%+ cache hit",
      "context_window": 128000,
      "max_completion_tokens": 8192,
      "temperature": 0.0,
      "top_p": 1.0,
      "api_backend": "chat_completions",
      "supported_in_api": true,
      "base_url": "https://api.deepseek.com/v1",
      "env_key": "DEEPSEEK_API_KEY",
      "byok": true,
      "auto_compact_threshold_percent": 80,
      "compaction_at_tokens": true,
      "show_model_fingerprint": true,
      "stream_tool_calls": true,
      "laziness_detector": {
        "enabled": true,
        "max_nudges_per_session": 3,
        "idle_threshold_ms": 8000,
        "min_confidence": 0.7
      },
      "pricing": {
        "input": 0.27,
        "cache_read": 0.014,
        "output": 1.1,
        "currency": "USD"
      }
    },
